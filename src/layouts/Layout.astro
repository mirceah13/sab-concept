---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = site.description,
  image = '/images/upload/hero.jpg',
  canonicalUrl,
} = Astro.props;

const pageTitle = title ? `${title} | ${site.name}` : `${site.name} — ${site.tagline}`;
const canonical = canonicalUrl ?? Astro.url.href;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, site.siteUrl).href} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_FR" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/images/upload/picto1.png" />
    <!-- Swiper + PhotoSwipe CSS -->
    <link rel="stylesheet" href="/swiper/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/photoswipe/photoswipe.css" />
    <link rel="stylesheet" href="/cc/cookieconsent.css" />

    <title>{pageTitle}</title>
  </head>
  <body>
    <CookieBanner />
    <Header currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer currentUrl={Astro.url.href} />
  </body>
</html>
