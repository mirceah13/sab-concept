---
import Layout from '../layouts/Layout.astro';
import SocialShare from '../components/SocialShare.astro';
import { site } from '../data/site';
---

<Layout
  title="Contactez notre entreprise tout corps d'état à Goult"
  description="Contactez Sab Concept pour obtenir un devis gratuit : construction, rénovation, maçonnerie à Goult (84220). Tél : 06 50 10 59 43."
>
  <!-- Page Hero -->
  <div class="bg-brand-dark text-white py-16 text-center">
    <h1 class="text-4xl md:text-5xl font-black">Contactez-nous</h1>
    <p class="mt-3 text-gray-300">Devis gratuit — Réponse rapide</p>
  </div>

  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Contact Form -->
      <div>
        <h2 class="text-2xl font-black text-brand-dark mb-3">Envoyer un message</h2>
        <p class="text-gray-500 mb-6">
          N'hésitez pas à nous contacter pour obtenir de plus amples renseignements et convenir d'un rendez-vous.
          Notre équipe s'engage à répondre dans les meilleurs délais.
        </p>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-5"
          id="contact-form"
        >
          <!-- Netlify honeypot -->
          <p class="hidden">
            <label>Ne pas remplir : <input name="bot-field" /></label>
          </p>
          <input type="hidden" name="form-name" value="contact" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="nom" class="block text-sm font-bold text-gray-700 mb-1">Nom *</label>
              <input
                type="text"
                id="nom"
                name="nom"
                required
                autocomplete="family-name"
                class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-brand-orange transition-colors"
              />
            </div>
            <div>
              <label for="prenom" class="block text-sm font-bold text-gray-700 mb-1">Prénom *</label>
              <input
                type="text"
                id="prenom"
                name="prenom"
                required
                autocomplete="given-name"
                class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-brand-orange transition-colors"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-bold text-gray-700 mb-1">Adresse e-mail *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-brand-orange transition-colors"
            />
          </div>

          <div>
            <label for="telephone" class="block text-sm font-bold text-gray-700 mb-1">Téléphone</label>
            <input
              type="tel"
              id="telephone"
              name="telephone"
              autocomplete="tel"
              class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-brand-orange transition-colors"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-bold text-gray-700 mb-1">Message *</label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-brand-orange transition-colors resize-y"
            ></textarea>
          </div>

          <div class="flex items-start gap-2">
            <input type="checkbox" id="rgpd" name="rgpd" required class="mt-1 accent-brand-orange" />
            <label for="rgpd" class="text-sm text-gray-600">
              J'ai lu et j'accepte la
              <a href="/politique-confidentialite" class="text-brand-orange hover:underline" target="_blank">
                politique de confidentialité
              </a> *
            </label>
          </div>

          <button type="submit" class="btn-primary w-full sm:w-auto text-base px-10 py-4">
            Envoyer le message
          </button>
        </form>
      </div>

      <!-- Contact Info sidebar -->
      <div>
        <h2 class="text-2xl font-black text-brand-dark mb-8">Nos coordonnées</h2>

        <div class="space-y-8">
          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-2">Adresse</h3>
            <address class="not-italic text-gray-700 leading-relaxed">
              {site.name}<br />
              {site.address}<br />
              {site.postalCode} {site.city}
            </address>
          </div>

          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-2">Téléphone</h3>
            <a href={site.phoneTel} class="text-2xl font-black text-brand-orange hover:underline">
              {site.phone}
            </a>
          </div>

          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-2">E-mail</h3>
            <a href={`mailto:${site.email}`} class="text-gray-700 hover:text-brand-orange transition-colors">
              {site.email}
            </a>
          </div>

          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-2">Zone d'intervention</h3>
            <p class="text-gray-700">
              Goult et ses environs dans un rayon de 50 km :<br />
              Apt, Bonnieux, Gordes, Roussillon, Pertuis, Manosque…
            </p>
          </div>

          <!-- Map placeholder -->
          <div class="bg-brand-gray p-6 text-center">
            <p class="text-gray-500 text-sm mb-3">Goult, Vaucluse (84220)</p>
            <a
              href="https://maps.google.com/?q=Goult+84220"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-outline text-sm"
            >
              Voir sur Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4">
    <SocialShare url={Astro.url.href} title="Contact — Sab Concept" />
  </div>
</Layout>
