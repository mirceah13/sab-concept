---
import Layout from '../layouts/Layout.astro';
import NewsCard from '../components/NewsCard.astro';
import SocialShare from '../components/SocialShare.astro';
import { chantiers } from '../data/chantiers';
---

<Layout
  title="Nos derniers chantiers de rénovation"
  description="Retrouvez les photos de nos chantiers de rénovation sur Goult, Apt et les environs. Découvrez la qualité du travail réalisé par Sab Concept."
>
  <!-- Page Hero -->
  <div class="bg-brand-dark text-white py-16 text-center">
    <h1 class="text-4xl md:text-5xl font-black">Nos derniers chantiers de rénovation</h1>
    <p class="mt-3 text-gray-300">Goult, Apt et les environs</p>
  </div>

  <!-- Intro -->
  <section class="max-w-4xl mx-auto px-4 py-10 text-center">
    <p class="text-lg text-gray-600 leading-relaxed">
      Retrouvez les photos de nos chantiers de rénovation sur Goult, Apt, et les environs. Faites-vous une idée de la qualité
      du travail réalisé par nos équipes. N'hésitez pas à
      <a href="/contact" class="text-brand-orange hover:underline">contacter notre entreprise tout corps d'état</a>
      pour nous présenter votre projet et obtenir un devis.
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-4 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {chantiers.map((c) => (
        <NewsCard
          title={c.title}
          date={c.date}
          excerpt={c.excerpt}
          thumbnail={c.thumbnail}
          href={`/chantiers/${c.slug}`}
        />
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4">
    <SocialShare url={Astro.url.href} title="Nos derniers chantiers — Sab Concept" />
  </div>
</Layout>
