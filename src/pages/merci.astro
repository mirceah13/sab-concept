---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Message envoyé - Sab Concept"
  description="Votre message a bien été envoyé. Nous vous répondrons dans les meilleurs délais."
>
  <div class="min-h-[60vh] flex items-center justify-center px-4 py-24">
    <div class="text-center max-w-md">
      <div class="text-6xl mb-6">✅</div>
      <h1 class="text-3xl font-black text-brand-dark mb-4">Message envoyé !</h1>
      <p class="text-gray-600 mb-8">
        Merci de nous avoir contactés. Nous vous répondrons dans les meilleurs délais.
      </p>
      <a href="/" class="btn-primary">Retour à l'accueil</a>
    </div>
  </div>
</Layout>
