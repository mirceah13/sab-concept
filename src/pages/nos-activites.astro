---
import Layout from '../layouts/Layout.astro';
import { services } from '../data/services';
import SocialShare from '../components/SocialShare.astro';
---

<Layout
  title="Votre artisan maçon tout corps d'état"
  description="Sab Concept, artisan maçon à Goult : maçonnerie, isolation, revêtements, menuiserie, électricité, plomberie. Devis gratuit."
>
  <!-- Page Hero -->
  <div
    class="relative py-24 text-white text-center"
    style="background: url('/images/upload/company-services.jpg') center/cover no-repeat;"
  >
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10">
      <h1 class="text-4xl md:text-5xl font-black">Votre artisan maçon tout corps d'état</h1>
      <p class="mt-3 text-gray-300 text-lg">Goult et ses environs — dans les 50 km</p>
    </div>
  </div>

  <!-- Intro -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <p class="text-lg text-gray-700 leading-relaxed">
      Faites appel à notre savoir-faire d'artisan maçon sur Goult et ses environs ! Spécialiste des travaux de construction,
      de rénovation et d'aménagement intérieur, Sab Concept met à votre disposition une équipe d'ouvriers hautement qualifiés.
      <a href="/contact" class="text-brand-orange hover:underline">Contactez notre entreprise tout corps d'état</a> pour prendre
      rendez-vous et obtenir un devis gratuit.
    </p>
  </section>

  <!-- Services sections -->
  {services.map((service) => (
    <section id={service.id} class="py-12 odd:bg-white even:bg-brand-gray">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl font-black text-brand-dark mb-4 flex items-center gap-3">
          <span class="text-3xl">{service.icon}</span>
          {service.title}
        </h2>
        <p class="text-gray-600 mb-4 leading-relaxed">{service.description}</p>
        <ul class="list-none space-y-2">
          {service.details.map(d => (
            <li class="flex items-start gap-2 text-gray-700">
              <span class="text-brand-orange font-bold mt-0.5">✓</span>
              {d}
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="py-12 bg-brand-dark text-white text-center">
    <div class="max-w-2xl mx-auto px-4">
      <p class="text-lg mb-4">
        Basés à Goult, nous intervenons dans les 50 km aux alentours. Découvrez quelques-uns de nos
        <a href="/en-images" class="text-brand-orange hover:underline">travaux de construction et de rénovation en images</a>.
      </p>
      <a href="/contact" class="btn-primary">Demander un devis gratuit</a>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4">
    <SocialShare url={Astro.url.href} title="Votre artisan maçon tout corps d'état — Sab Concept" />
  </div>
</Layout>
