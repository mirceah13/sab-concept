---
import Layout from '../layouts/Layout.astro';
import NewsCard from '../components/NewsCard.astro';
import SocialShare from '../components/SocialShare.astro';
import { actualites } from '../data/actualites';
---

<Layout
  title="Les nouveautés de notre entreprise de construction de maisons"
  description="Retrouvez toutes les actualités de Sab Concept : nouveaux chantiers, promotions, informations sur nos prestations."
>
  <!-- Page Hero -->
  <div class="bg-brand-dark text-white py-16 text-center">
    <h1 class="text-4xl md:text-5xl font-black">Actualités</h1>
    <p class="mt-3 text-gray-300">Les nouveautés de notre entreprise de construction</p>
  </div>

  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {actualites.map((a) => (
        <NewsCard
          title={a.title}
          date={a.date}
          excerpt={a.excerpt}
          thumbnail={a.image}
          href={`/actualites/${a.slug}`}
        />
      ))}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4">
    <SocialShare url={Astro.url.href} title="Actualités — Sab Concept" />
  </div>
</Layout>
