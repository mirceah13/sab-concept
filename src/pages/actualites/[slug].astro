---
import Layout from '../../layouts/Layout.astro';
import SocialShare from '../../components/SocialShare.astro';
import { actualites, type Actualite } from '../../data/actualites';

export async function getStaticPaths() {
  return actualites.map((a) => ({
    params: { slug: a.slug },
    props: { article: a },
  }));
}

interface Props {
  article: Actualite;
}

const { article } = Astro.props;

// Previous / Next navigation
const idx = actualites.findIndex((a) => a.slug === article.slug);
const prev = actualites[idx - 1];
const next = actualites[idx + 1];
---

<Layout
  title={article.title}
  description={article.excerpt}
  image={article.image}
>
  <!-- Page hero -->
  <div
    class="relative py-24 text-white text-center"
    style={`background: url('${article.image}') center/cover no-repeat;`}
  >
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 px-4">
      <p class="text-sm uppercase tracking-widest text-brand-orange font-bold mb-2">Actualités</p>
      <h1 class="text-3xl md:text-5xl font-black">{article.title}</h1>
      <time class="block mt-3 text-gray-300">{article.date}</time>
    </div>
  </div>

  <article class="max-w-4xl mx-auto px-4 py-12">
    <!-- Main image -->
    <img
      src={article.image}
      alt={article.title}
      class="w-full max-h-96 object-cover mb-8"
      loading="eager"
      width="900"
      height="500"
    />

    <!-- Content -->
    <div
      class="prose prose-gray prose-headings:font-black max-w-none text-gray-700 leading-relaxed mb-10"
      set:html={article.content}
    />

    <!-- Back link -->
    <a href="/actualites" class="inline-flex items-center gap-2 text-brand-orange hover:underline font-bold">
      ← Retour aux actualités
    </a>

    <!-- Prev / Next -->
    {(prev || next) && (
      <nav class="flex justify-between mt-8 pt-6 border-t border-gray-200 gap-4" aria-label="Navigation articles">
        {prev ? (
          <a href={`/actualites/${prev.slug}`} class="text-sm text-gray-500 hover:text-brand-orange transition-colors max-w-xs">
            ← {prev.title}
          </a>
        ) : <span />}
        {next && (
          <a href={`/actualites/${next.slug}`} class="text-sm text-gray-500 hover:text-brand-orange transition-colors max-w-xs text-right">
            {next.title} →
          </a>
        )}
      </nav>
    )}

    <SocialShare url={Astro.url.href} title={article.title} />
  </article>
</Layout>
