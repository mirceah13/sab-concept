---
// FeatureBadges.astro — Swiper loop of 4 brand badges
const badges = [
  { label: 'Pour tous budgets',              img: '/images/upload/picto2.png' },
  { label: 'Particuliers et professionnels', img: '/images/upload/picto3.png' },
  { label: 'Tout corps d\'état',             img: '/images/upload/picto4.png' },
  { label: 'Devis gratuits',                 img: '/images/upload/picto1.png' },
];
---

<section class="bg-brand-gray py-10 overflow-hidden" aria-label="Points forts">
  <div class="swiper badges-swiper">
    <div class="swiper-wrapper items-center">
      {badges.concat(badges).map((badge) => (
        <div class="swiper-slide !w-auto px-8">
          <div class="flex flex-col items-center gap-3 text-center select-none">
            <img
              src={badge.img}
              alt={badge.label}
              width="64"
              height="64"
              class="w-16 h-16 object-contain"
              loading="lazy"
            />
            <span class="font-bold uppercase text-sm tracking-wide text-brand-dark">{badge.label}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Autoplay } from 'swiper/modules';

  new Swiper('.badges-swiper', {
    modules: [Autoplay],
    loop: true,
    slidesPerView: 'auto',
    spaceBetween: 20,
    autoplay: { delay: 0, disableOnInteraction: false },
    speed: 3000,
    allowTouchMove: false,
  });
</script>
