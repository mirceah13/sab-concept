---
import { services } from '../data/services';

// Map service IDs to SVG path data for clean icons
const iconPaths: Record<string, string> = {
  macon:      'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z M9 22V12h6v10',
  iso:        'M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9',
  revetement: 'M4 5a1 1 0 011-1h4a1 1 0 010 2H6v3h12V6h-3a1 1 0 010-2h4a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V5z M4 13h16',
  menuis:     'M8 3H5a2 2 0 00-2 2v3m18 0V5a2 2 0 00-2-2h-3M3 16v3a2 2 0 002 2h3m8 0h3a2 2 0 002-2v-3M12 8v8m-4-4h8',
  elec:       'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  plomb:      'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18',
};
---

<section class="py-20 bg-brand-gray" id="services">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-14">
      <span class="inline-block text-brand-orange text-xs font-bold uppercase tracking-widest mb-3">Nos expertises</span>
      <h2 class="section-title centered mx-auto">Les prestations de notre entreprise tout corps d'état</h2>
      <p class="text-gray-500 mt-6 max-w-2xl mx-auto">
        Avec Sab Concept, profitez du savoir-faire d'un artisan maçon tout corps d'état. 
        <a href="/avis-clients" class="text-brand-orange hover:underline">Consultez les avis clients</a> pour noter la qualité du travail effectué.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <a
          href={`/nos-activites${service.anchor}`}
          class="group bg-white border border-gray-100 hover:border-brand-blue/30 p-8 shadow-sm hover:shadow-lg transition-all duration-300 rounded-sm"
          aria-label={service.title}
        >
          <div class="w-12 h-12 bg-brand-blue/10 group-hover:bg-brand-orange rounded-sm flex items-center justify-center mb-5 transition-colors duration-300">
            <svg class="w-6 h-6 text-brand-blue group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[service.id] ?? 'M12 4v16m8-8H4'} />
            </svg>
          </div>
          <h3 class="font-black text-lg text-brand-dark mb-2 group-hover:text-brand-orange transition-colors">
            {service.title}
          </h3>
          <p class="text-sm text-gray-500 leading-relaxed">{service.description}</p>
          <span class="inline-block mt-4 text-xs font-bold text-brand-blue uppercase tracking-wide group-hover:text-brand-orange transition-colors">
            En savoir plus →
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
