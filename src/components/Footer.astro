---
import { site } from '../data/site';

interface Props {
  currentUrl: string;
}
const { currentUrl } = Astro.props;

const fbShare = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(currentUrl)}`;
const xShare  = `https://twitter.com/intent/tweet?url=${encodeURIComponent(currentUrl)}`;
---

<footer class="bg-brand-dark text-white mt-16">
  <!-- Top footer band -->
  <div class="max-w-7xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-10">

    <!-- Company info -->
    <div>
      <div class="text-2xl font-black tracking-tight mb-3">
        <span class="text-brand-orange">SAB</span> CONCEPT
      </div>
      <p class="text-sm text-gray-300 leading-relaxed">
        {site.tagline}<br />
        {site.address}<br />
        {site.postalCode} {site.city}
      </p>
      <a href={site.phoneTel} class="block mt-3 text-brand-orange font-bold hover:underline">
        {site.phone}
      </a>
      <a href={`mailto:${site.email}`} class="block text-sm text-gray-400 hover:text-white mt-1">
        {site.email}
      </a>
    </div>

    <!-- Quick links -->
    <div>
      <h3 class="font-bold uppercase tracking-widest mb-4 text-sm text-gray-400">Navigation</h3>
      <ul class="space-y-2 text-sm">
        {[
          ['Accueil',                   '/'],
          ['Nos activités',             '/nos-activites'],
          ['Actualités',                '/actualites'],
          ['Nos derniers chantiers',    '/nos-derniers-chantiers'],
          ['En images',                 '/en-images'],
          ['Avis clients',              '/avis-clients'],
          ['Contact',                   '/contact'],
        ].map(([label, href]) => (
          <li>
            <a href={href} class="text-gray-300 hover:text-brand-orange transition-colors">{label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Social + Legal -->
    <div>
      <h3 class="font-bold uppercase tracking-widest mb-4 text-sm text-gray-400">Nous suivre</h3>
      <div class="flex gap-3 mb-6">
        <a
          href={site.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-gray-700 hover:bg-brand-orange text-white px-4 py-2 text-sm transition-colors"
          aria-label="Instagram"
        >
          Instagram
        </a>
        <a
          href={fbShare}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-gray-700 hover:bg-blue-600 text-white px-4 py-2 text-sm transition-colors"
          aria-label="Partager sur Facebook"
        >
          Facebook
        </a>
        <a
          href={xShare}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-gray-700 hover:bg-gray-500 text-white px-4 py-2 text-sm transition-colors"
          aria-label="Partager sur X"
        >
          X
        </a>
      </div>

      <ul class="space-y-2 text-xs text-gray-500">
        <li><a href="/mentions-legales" class="hover:text-gray-300 transition-colors">Mentions légales</a></li>
        <li><a href="/politique-confidentialite" class="hover:text-gray-300 transition-colors">Politique de confidentialité</a></li>
        <li>
          <button
            id="cc-show-preferences"
            class="hover:text-gray-300 transition-colors underline bg-transparent border-0 cursor-pointer text-xs text-gray-500"
          >
            Paramètres cookies
          </button>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-700">
    <div class="max-w-7xl mx-auto px-4 py-4 text-center text-xs text-gray-600">
      © {new Date().getFullYear()} {site.name} — SIRET {site.siret} — TVA {site.tva}
    </div>
  </div>
</footer>

<script>
  document.getElementById('cc-show-preferences')?.addEventListener('click', () => {
    // Trigger vanilla-cookieconsent preferences panel
    if (typeof (window as any).CookieConsent !== 'undefined') {
      (window as any).CookieConsent.showPreferences();
    }
  });
</script>
