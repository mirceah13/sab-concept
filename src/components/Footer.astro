---
import { site } from '../data/site';

interface Props {
  currentUrl: string;
}
const { currentUrl } = Astro.props;

const fbShare = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(currentUrl)}`;
const xShare  = `https://twitter.com/intent/tweet?url=${encodeURIComponent(currentUrl)}`;
---

<footer class="bg-brand-dark text-white mt-16">
  <!-- Blue accent top bar -->
  <div class="bg-brand-blue h-1 w-full"></div>

  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 py-14 grid grid-cols-1 md:grid-cols-3 gap-12">

    <!-- Company info with logo -->
    <div>
      <a href="/" class="inline-block mb-5">
        <img
          src="/images/upload/logo.png"
          alt="Sab Concept"
          width="140"
          height="56"
          class="h-12 w-auto object-contain"
          loading="lazy"
        />
      </a>
      <p class="text-sm text-gray-400 leading-relaxed mb-4">
        {site.tagline}<br />
        {site.address}<br />
        {site.postalCode} {site.city}
      </p>
      <a href={site.phoneTel} class="inline-flex items-center gap-2 text-brand-orange font-bold hover:underline">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79a15.7 15.7 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.56 21 3 13.44 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.46.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"/></svg>
        {site.phone}
      </a>
      <a href={`mailto:${site.email}`} class="block text-sm text-gray-400 hover:text-white mt-1 transition-colors">{site.email}</a>
    </div>

    <!-- Quick links -->
    <div>
      <h3 class="font-bold uppercase tracking-widest mb-5 text-xs text-gray-400 border-b border-gray-700 pb-3">Navigation</h3>
      <ul class="space-y-2.5 text-sm">
        {[
          ['Accueil',                   '/'],
          ['Nos activités',             '/nos-activites'],
          ['Actualités',                '/actualites'],
          ['Nos derniers chantiers',    '/nos-derniers-chantiers'],
          ['En images',                 '/en-images'],
          ['Avis clients',              '/avis-clients'],
          ['Contact',                   '/contact'],
        ].map(([label, href]) => (
          <li>
            <a href={href} class="text-gray-400 hover:text-brand-orange transition-colors flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-brand-orange/60 rounded-full flex-shrink-0"></span>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Social + Legal -->
    <div>
      <h3 class="font-bold uppercase tracking-widest mb-5 text-xs text-gray-400 border-b border-gray-700 pb-3">Suivez-nous</h3>
      <div class="flex gap-3 mb-8">
        <a
          href={site.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 bg-white/5 hover:bg-brand-orange text-white px-4 py-2 text-sm transition-all duration-200 rounded-sm"
          aria-label="Instagram"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          Instagram
        </a>
        <a
          href={fbShare}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 bg-white/5 hover:bg-[#4267B2] text-white px-4 py-2 text-sm transition-all duration-200 rounded-sm"
          aria-label="Partager sur Facebook"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          Facebook
        </a>
      </div>

      <ul class="space-y-2 text-xs text-gray-600">
        <li><a href="/mentions-legales" class="hover:text-gray-300 transition-colors">Mentions légales</a></li>
        <li><a href="/politique-confidentialite" class="hover:text-gray-300 transition-colors">Politique de confidentialité</a></li>
        <li>
          <button
            id="cc-show-preferences"
            class="hover:text-gray-300 transition-colors underline bg-transparent border-0 cursor-pointer text-xs text-gray-600"
          >
            Paramètres cookies
          </button>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between text-xs text-gray-600 gap-2">
      <span>© {new Date().getFullYear()} {site.name} — Tous droits réservés</span>
      <span>SIRET {site.siret} — TVA {site.tva}</span>
    </div>
  </div>
</footer>

<script>
  document.getElementById('cc-show-preferences')?.addEventListener('click', () => {
    // Trigger vanilla-cookieconsent preferences panel
    if (typeof (window as any).CookieConsent !== 'undefined') {
      (window as any).CookieConsent.showPreferences();
    }
  });
</script>
