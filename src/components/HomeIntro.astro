---
// HomeIntro.astro — the "Sab Concept : un spécialiste du bâtiment" intro section
import { site } from '../data/site';
---
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <!-- Text column -->
    <div>
      <h2 class="section-title">Sab Concept : un spécialiste du bâtiment à votre service</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Basée à Goult, notre entreprise de construction et de rénovation intervient dans les 50 km aux alentours :
      </p>
      <ul class="list-none space-y-2 mb-6">
        {[
          'Construction',
          'Rénovation tout corps d\'état',
          'Aménagement intérieur et décoration',
        ].map(item => (
          <li class="flex items-center gap-2 text-gray-700">
            <span class="text-brand-orange font-bold">✓</span>
            {item}
          </li>
        ))}
      </ul>
      <p class="text-gray-600 leading-relaxed mb-6">
        Notre entreprise tout corps d'état réalise des travaux de grande qualité pour les particuliers et les professionnels.
        Nous assurons une gestion complète de chaque projet, dans le respect du budget et des délais impartis.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/contact" class="btn-primary">Demander un devis gratuit</a>
        <a href="/en-images" class="btn-outline">Voir nos réalisations</a>
      </div>
    </div>

    <!-- Image column -->
    <div class="relative">
      <img
        src="/images/upload/company-home.jpg"
        alt="Entreprise tout corps d'état à Goult — Sab Concept"
        class="w-full object-cover shadow-lg"
        loading="lazy"
        width="600"
        height="450"
      />
      <div class="absolute -bottom-4 -left-4 bg-brand-orange text-white px-6 py-4 hidden md:block">
        <p class="text-2xl font-black leading-none">{site.phone}</p>
        <p class="text-xs mt-1 uppercase tracking-wide">Devis gratuit</p>
      </div>
    </div>
  </div>
</section>
