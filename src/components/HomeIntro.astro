---
// HomeIntro.astro — the "Sab Concept : un spécialiste du bâtiment" intro section
import { site } from '../data/site';
---
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!-- Text column -->
    <div>
      <span class="inline-block text-brand-orange text-xs font-bold uppercase tracking-widest mb-3">Entreprise tout corps d'état</span>
      <h2 class="section-title">Sab Concept : un spécialiste du bâtiment à votre service</h2>
      <p class="text-gray-600 leading-relaxed mb-5 text-base">
        Basée à Goult, notre entreprise de construction et de rénovation intervient dans les 50&nbsp;km aux alentours.
        Nous assurons une gestion complète de chaque projet, dans le respect du budget et des délais impartis.
      </p>
      <ul class="space-y-3 mb-8">
        {[
          'Construction neuve et rénovation complète',
          'Rénovation tout corps d\'état',
          'Aménagement intérieur et décoration',
        ].map(item => (
          <li class="flex items-center gap-3 text-gray-700">
            <span class="flex-shrink-0 w-5 h-5 bg-brand-orange rounded-full flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
            </span>
            <span class="font-medium">{item}</span>
          </li>
        ))}
      </ul>
      <div class="flex flex-wrap gap-4">
        <a href="/contact" class="btn-primary">Demander un devis gratuit</a>
        <a href="/en-images" class="btn-outline">Voir nos réalisations</a>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-3 gap-4 mt-10 pt-8 border-t border-gray-100">
        {[
          { number: '15+', label: 'Ans d\'expérience' },
          { number: '500+', label: 'Chantiers réalisés' },
          { number: '50km', label: 'Rayon d\'intervention' },
        ].map(stat => (
          <div class="text-center">
            <div class="text-2xl font-black text-brand-blue leading-none">{stat.number}</div>
            <div class="text-xs text-gray-500 mt-1 uppercase tracking-wide">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Image column -->
    <div class="relative">
      <div class="absolute -top-4 -left-4 w-full h-full bg-brand-blue/10 rounded-sm -z-10"></div>
      <img
        src="/images/upload/company-home.jpg"
        alt="Entreprise tout corps d'état à Goult — Sab Concept"
        class="w-full object-cover shadow-xl rounded-sm"
        loading="lazy"
        width="600"
        height="450"
      />
      <div class="absolute -bottom-5 -right-5 bg-brand-orange text-white px-6 py-4 shadow-lg hidden md:block rounded-sm">
        <p class="text-xl font-black leading-none">{site.phone}</p>
        <p class="text-xs mt-1 uppercase tracking-wide opacity-90">Devis gratuit &amp; rapide</p>
      </div>
    </div>
  </div>
</section>
